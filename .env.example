# --- Server ---
PORT=8080
GIN_MODE=release

# --- Database (Postgres) ---
POSTGRESQL_URL=postgres://user:password@host:5432/voicechess?sslmode=disable

# --- AI: Ollama gateway (primary) ---
# Point this at the VoiceChess Ollama voice/LLM service.
# On Railway use the internal URL of your Ollama service, e.g. http://ollama.railway.internal:11434/api/chat
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_API_KEY=
OLLAMA_MODEL_NAME=qwen2.5:3b

# --- AI: Gemini (only used by /api/chess/ai and /api/analysis/fen-from-image vision) ---
GEMINI_API_KEY=YOUR_GEMINI
