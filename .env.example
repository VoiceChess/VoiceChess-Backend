# --- Server ---
PORT=8080
GIN_MODE=release

# --- Database (Postgres) ---
POSTGRESQL_URL=postgres://user:password@host:5432/voicechess?sslmode=disable

# --- Firebase Auth ---
# Use FIREBASE_SERVICE_ACCOUNT_JSON in Railway/GitHub secrets, or FIREBASE_CREDENTIALS_FILE locally.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CREDENTIALS_FILE=firebase-service-account.json

# --- AI: Ollama gateway ---
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_API_KEY=
OLLAMA_MODEL_NAME=qwen2.5:3b

# --- AI: self-hosted image-to-FEN service ---
FEN_DETECT_URL=http://localhost:5000/api/detect
